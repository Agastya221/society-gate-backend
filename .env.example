# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"

# Server
PORT=4000
NODE_ENV=development

# Redis
REDIS_URL="redis://default:password@host:port"

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
S3_UPLOAD_EXPIRY=300
S3_VIEW_EXPIRY=3600

# MSG91 (SMS OTP)
MSG91_API_KEY=your-msg91-api-key
MSG91_SENDER_ID=SOCIET
MSG91_TEMPLATE_ID=   # Optional: your DLT-registered MSG91 template ID

# MSG91 Widget Auth Key — REQUIRED for OTP Widget verification
# Get this from: MSG91 Dashboard → OTP Widget → select your widget → copy Auth Key
# This is DIFFERENT from MSG91_API_KEY
MSG91_WIDGET_AUTH_KEY=your-msg91-widget-auth-key-here

# Socket.IO CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000
