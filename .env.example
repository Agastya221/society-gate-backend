# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Optional: Prisma migrations use this direct/non-pooled URL when present.
# If omitted, prisma.config.ts derives Neon direct URL by removing "-pooler" from DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://user:password@direct-host/dbname?sslmode=require"

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"

# Server
PORT=4000
NODE_ENV=development

# Redis
REDIS_URL="redis://default:password@host:port"

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
S3_UPLOAD_EXPIRY=300
S3_VIEW_EXPIRY=3600

# MSG91 OTP Configuration
# MSG91_AUTH_KEY   = Your account authkey (Dashboard → Authkey). Used by backend to verify OTP tokens with MSG91 API.
# MSG91_WIDGET_ID  = Your OTP Widget ID (Dashboard → OTP Widget). Used by frontend React Native SDK only.
# MSG91_TOKEN_AUTH = Your OTP Widget Token (Dashboard → OTP Widget → Token). Used by frontend React Native SDK only.
MSG91_AUTH_KEY=your-msg91-account-authkey-here
MSG91_WIDGET_ID=your-msg91-widget-id-here
MSG91_TOKEN_AUTH=your-msg91-widget-token-here
MSG91_RESIDENT_INVITE_TEMPLATE_ID=your-resident-invite-flow-template-id

# Resident app invitation links/delivery
RESIDENT_APP_DOWNLOAD_URL=https://your-app.example.com/download
EMAIL_INVITE_WEBHOOK_URL=https://your-email-provider.example.com/send

# Firebase Admin SDK
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line string
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Socket.IO CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000

# Cashfree Payment Gateway
# Sandbox: https://sandbox.cashfree.com/pg, Production: https://api.cashfree.com/pg
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2025-01-01
CASHFREE_PG_CLIENT_ID=your-cashfree-pg-client-id
CASHFREE_PG_CLIENT_SECRET=your-cashfree-pg-client-secret
CASHFREE_RETURN_URL=https://your-app.example.com/payment/return?invoice_id={invoice_id}&order_id={order_id}
CASHFREE_NOTIFY_URL=https://your-api.example.com/api/v1/payments/cashfree/webhook
